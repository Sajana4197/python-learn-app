# Supabase (free tier project — https://supabase.com/dashboard)
# Create a project, then copy these from Project Settings > API.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Google and Apple sign-in: there are no app-level env vars for these —
# the OAuth credentials live in your Supabase dashboard, not in this app.
#   Google: Authentication > Providers > Google, using a Web OAuth client
#           ID/secret from Google Cloud Console.
#   Apple:  Authentication > Providers > Apple, using your Services ID,
#           Team ID, Key ID, and private key from your Apple Developer
#           account. Also requires the "Sign In with Apple" capability
#           enabled for this app's bundle identifier.
#   Both also require `indent://` added under Authentication > URL
#   Configuration > Redirect URLs in Supabase.
# AI provider for the in-app tutor (wired up in Phase 7).
# Self-hosted Ollama only — no third-party free-tier APIs (rate limits were
# ruled out as unacceptable). Point this at a server you provision and run
# yourself, exposing Ollama's OpenAI-compatible endpoint
# (e.g. http://your-server:11434/v1). Leave blank during early phases —
# the AI Tutor screen will show an "offline" state until this is set.
EXPO_PUBLIC_OLLAMA_BASE_URL=
EXPO_PUBLIC_OLLAMA_MODEL=llama3.1:8b
