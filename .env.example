# AI provider for the in-app tutor (wired up in Phase 7).
# Self-hosted Ollama only — no third-party free-tier APIs (rate limits were
# ruled out as unacceptable). Point this at a server you provision and run
# yourself, exposing Ollama's OpenAI-compatible endpoint
# (e.g. http://your-server:11434/v1). Leave blank during early phases —
# the AI Tutor screen will show an "offline" state until this is set.
EXPO_PUBLIC_OLLAMA_BASE_URL=
EXPO_PUBLIC_OLLAMA_MODEL=llama3.1:8b
